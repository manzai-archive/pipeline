# Required for speaker diarization (pyannote).
# 1. Create token: https://hf.co/settings/tokens
# 2. Accept agreement: https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Where to write draft script.md files.
# Default: ../web/src/content/manzai
# MANZAI_CONTENT_DIR=

# Name credited in `contributed_by` frontmatter of generated scripts.
# Default: wheatfox
# MANZAI_CONTRIBUTOR=

# Whisper backend: auto | mlx | faster
# - mlx: Apple-Silicon GPU via MLX (Metal + Neural Engine), much faster
# - faster: faster-whisper (CTranslate2), CPU on Mac, CUDA on NVIDIA
# - auto: mlx on Apple Silicon, faster elsewhere (default)
# WHISPER_BACKEND=auto

# Whisper model size: tiny | base | small | medium | large-v3 | large-v3-turbo
# WHISPER_MODEL=large-v3

# MLX model repo override (defaults to mlx-community/whisper-large-v3-mlx)
# MLX_WHISPER_REPO=

# faster-whisper compute backend (only used when WHISPER_BACKEND=faster)
# WHISPER_DEVICE=cpu          # cpu | cuda
# WHISPER_COMPUTE_TYPE=int8   # int8 | int8_float16 | float16 | float32

# Diarization (pyannote) device: auto | mps | cuda | cpu
# Auto picks mps on Apple Silicon, cuda if NVIDIA, otherwise cpu.
# Some pyannote ops may not be implemented on MPS — falls back to CPU silently.
# PYANNOTE_DEVICE=auto
