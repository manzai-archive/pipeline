# Required for speaker diarization (pyannote).
# 1. Create token: https://hf.co/settings/tokens
# 2. Accept agreement: https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=

# Where to write draft script.md files.
# Default: ../web/src/content/manzai
# MANZAI_CONTENT_DIR=

# Whisper model size: tiny | base | small | medium | large-v3 | large-v3-turbo
# WHISPER_MODEL=large-v3

# Compute backend
# WHISPER_DEVICE=cpu          # cpu | cuda | mps
# WHISPER_COMPUTE_TYPE=int8   # int8 | int8_float16 | float16 | float32
